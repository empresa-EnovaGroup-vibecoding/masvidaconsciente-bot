# ─── WhatsApp (Meta Cloud API) ───────────────────────────────
# Estos 5 datos son lo único que cambia entre un cliente y otro.
META_PHONE_NUMBER_ID=
META_WABA_ID=100526692613101
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=cambia-esto-por-algo-secreto
META_APP_SECRET=

# ─── Base de datos (PostgreSQL en el VPS) ────────────────────
DATABASE_URL=postgresql+asyncpg://masvida:password@postgres:5432/masvidaconsciente

# ─── Redis (en el VPS) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Motor de IA (OpenRouter) ────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MODEL_FALLBACK=openai/gpt-4.1

# ─── Comportamiento ──────────────────────────────────────────
BUFFER_SEGUNDOS=15
CONVERSACION_TTL=86400
MAX_ITERACIONES_AGENTE=6

# ─── Negocio (identidad del cliente) ─────────────────────────
NEGOCIO_NOMBRE=masvidaconsciente
NEGOCIO_UBICACION=Cabudare, Venezuela

# ─── Dashboard / Seguridad (OBLIGATORIO) ─────────────────────
# JWT_SECRET: llave para firmar las sesiones del dashboard. DEBE ser larga y
# aleatoria (minimo 32 caracteres). Sin ella, el bot NO arranca (a proposito).
# Genera una con:  openssl rand -hex 32
JWT_SECRET=
# Credenciales del admin del dashboard. ADMIN_PASSWORD debe ser fuerte (minimo
# 8 caracteres) y NO puede ser un valor por defecto. Sin ella, el bot NO arranca.
ADMIN_EMAIL=admin@masvidaconsciente.com
ADMIN_PASSWORD=

# ─── Aviso a la duena ────────────────────────────────────────
# Numero (formato internacional, ej. +584264399792) que recibe el aviso cuando
# entra un pago. En pruebas: tu propio numero. En produccion: el de la clienta.
# Tambien se puede editar sin redeploy desde la tabla `configuracion`.
DUENO_TELEFONO=

# ─── Tasa BCV (USD -> Bs) ────────────────────────────────────
# URL de la API de tasa (Cotizave). TASA_API_KEY solo si el plan lo exige.
# TASA_MANUAL_DEFAULT: tasa de respaldo si la API y la config fallan (ej. 40.50).
TASA_API_URL=
TASA_API_KEY=
TASA_TTL=3600
TASA_MANUAL_DEFAULT=

# ─── Comprobantes de pago ────────────────────────────────────
# Carpeta donde se guardan las imagenes/PDF de los comprobantes (volumen del VPS).
COMPROBANTES_DIR=/data/comprobantes
